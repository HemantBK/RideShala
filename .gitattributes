# Auto-detect text files and normalize line endings
* text=auto

# Force LF for all code files (prevents CRLF issues across OS)
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.txt text eol=lf
*.html text eol=lf
*.css text eol=lf

# Binary files (don't touch these)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.safetensors binary
*.gguf binary
*.bin binary
