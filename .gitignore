# ╔══════════════════════════════════════════════════════════════════╗
# ║                    RideShala .gitignore                           ║
# ║  NEVER push secrets, API keys, credentials, or personal data   ║
# ╚══════════════════════════════════════════════════════════════════╝

# ═══════════════════════════════════════════════════════════════════
# SECRETS & SENSITIVE FILES (CRITICAL — NEVER PUSH THESE)
# ═══════════════════════════════════════════════════════════════════
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
*.jks
*.keystore
credentials.json
service-account.json
serviceAccountKey.json
secrets.yaml
secrets.yml
*.secret
token.json
oauth2.json

# API keys that might be saved in files
anthropic_key.txt
groq_key.txt
supabase_key.txt
google_credentials.json

# SSH keys (if accidentally placed in project)
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
known_hosts

# ═══════════════════════════════════════════════════════════════════
# PYTHON
# ═══════════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
sdist/
wheels/
*.whl

# Virtual environments
.venv/
venv/
env/
ENV/
.conda/

# Testing & coverage
.mypy_cache/
.pytest_cache/
.ruff_cache/
.tox/
.nox/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
nosetests.xml

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# Type checking
.pytype/
.pyre/

# ═══════════════════════════════════════════════════════════════════
# NODE.JS / NEXT.JS
# ═══════════════════════════════════════════════════════════════════
node_modules/
.next/
out/
.turbo/
.vercel/
.cache/
*.tsbuildinfo
.npm/
.yarn/
.pnp.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache

# ═══════════════════════════════════════════════════════════════════
# FLUTTER / DART
# ═══════════════════════════════════════════════════════════════════
apps/mobile/.dart_tool/
apps/mobile/build/
apps/mobile/.flutter-plugins
apps/mobile/.flutter-plugins-dependencies
apps/mobile/.packages
apps/mobile/ios/Pods/
apps/mobile/ios/.symlinks/
apps/mobile/android/.gradle/
apps/mobile/android/app/build/
apps/mobile/android/local.properties
*.apk
*.aab
*.ipa
*.dSYM.zip
*.dSYM

# ═══════════════════════════════════════════════════════════════════
# ML MODELS & LARGE FILES (downloaded at runtime, NOT in git)
# ═══════════════════════════════════════════════════════════════════
models/
*.bin
*.safetensors
*.gguf
*.onnx
*.pt
*.pth
*.h5
*.pkl
*.joblib
*.npy
*.npz

# MLflow artifacts
mlruns/
mlflow-artifacts/

# Hugging Face cache
.cache/huggingface/

# ═══════════════════════════════════════════════════════════════════
# DATABASES & DOCKER VOLUMES (local dev data, NOT in git)
# ═══════════════════════════════════════════════════════════════════
pgdata/
qdrant_data/
qdrant_storage/
redis_data/
meili_data/
mongo_data/
*.db
*.sqlite
*.sqlite3

# Docker
docker-compose.override.yml

# ═══════════════════════════════════════════════════════════════════
# LOGS & TEMPORARY FILES
# ═══════════════════════════════════════════════════════════════════
logs/
*.log
*.log.*
tmp/
temp/
.tmp/

# ═══════════════════════════════════════════════════════════════════
# IDE & EDITOR FILES
# ═══════════════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
*.bak
*.orig
*.rej

# ═══════════════════════════════════════════════════════════════════
# OS FILES
# ═══════════════════════════════════════════════════════════════════
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ═══════════════════════════════════════════════════════════════════
# CLAUDE CODE (development session files)
# ═══════════════════════════════════════════════════════════════════
.claude/
!.claude/launch.json

# ═══════════════════════════════════════════════════════════════════
# BACKUPS & ARCHIVES (not source code)
# ═══════════════════════════════════════════════════════════════════
*.sql.gz
*.sql.bak
*.dump
*.tar.gz
*.zip
!data/seeds/*.json
data/reviews.json
data/mileage_logs.json
data/service_logs.json
data/contributions.json
data/feedback.json
