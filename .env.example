# RideShala Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file — it contains secrets
#
# ╔═══════════════════════════════════════════════════════╗
# ║  RideShala is 100% FREE by default.                    ║
# ║  Everything below marked [FREE] costs nothing.       ║
# ║  Items marked [OPTIONAL-PAID] are enhancements only. ║
# ║  The system works fully without any paid service.     ║
# ╚═══════════════════════════════════════════════════════╝

# ─── Database [FREE — self-hosted] ─────────────────────
DATABASE_URL=postgresql://rideshala:changeme@localhost:5432/rideshala
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=changeme_meili_key

# ─── vLLM Self-hosted LLM [FREE — runs on your GPU] ───
# DEFAULT MODEL: Mistral 7B Instruct (Apache 2.0, zero restrictions)
# Alternative: meta-llama/Llama-3.1-8B-Instruct (Llama License, 700M MAU limit)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=changeme_vllm_key
VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ─── vLLM Embeddings [FREE — runs on your GPU] ────────
EMBEDDING_BASE_URL=http://localhost:8001/v1
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5

# ─── [OPTIONAL-PAID] Claude API ────────────────────────
# NOT required. System works 100% on vLLM alone.
# Only add this if you want premium reasoning quality.
# Cost: ~$3/$15 per 1M input/output tokens.
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── [OPTIONAL-PAID] Groq API ─────────────────────────
# NOT required. Free tier: 30 requests/minute.
# Useful as a faster fallback when vLLM is busy.
# GROQ_API_KEY=gsk_your-key-here
# GROQ_MODEL=llama-3.1-70b-versatile

# ─── Auth [FREE — self-hosted JWT] ─────────────────────
# Default: built-in JWT auth (no external service needed)
# Optional: Supabase Auth for social login (free tier: 50K MAU)
AUTH_SECRET_KEY=changeme-generate-a-random-64-char-string
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=1440
# SUPABASE_URL=https://your-project.supabase.co  # [OPTIONAL-PAID]
# SUPABASE_ANON_KEY=changeme                       # [OPTIONAL-PAID]

# ─── Maps [FREE — OpenStreetMap + Nominatim] ──────────
# Default: OpenStreetMap + Nominatim (100% free, open source)
NOMINATIM_URL=https://nominatim.openstreetmap.org
OSRM_URL=https://router.project-osrm.org
# GOOGLE_MAPS_API_KEY=changeme  # [OPTIONAL-PAID] Only if you need Google Maps

# ─── Weather [FREE — Open-Meteo, no API key needed] ───
# Default: Open-Meteo (100% free, open source, no key required)
OPEN_METEO_URL=https://api.open-meteo.com/v1
# OPENWEATHER_API_KEY=changeme  # [OPTIONAL-PAID] Alternative if you prefer

# ─── Rate Limits ──────────────────────────────────────
RATE_LIMIT_ANONYMOUS_CHAT=10
RATE_LIMIT_AUTH_CHAT=30

# ─── App Config ────────────────────────────────────────
APP_ENV=development
APP_PORT=8080
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
